__pycache__/
*.py[cod]

# Exclude tests from Docker build context
/tests/

# Exclude git metadata
.git/

# Virtual environments and local configuration
.venv/
.env

# Build artifacts
build/
dist/
*.egg-info/
node_modules/
frontend/

# OS-specific files
.DS_Store
Thumbs.db
